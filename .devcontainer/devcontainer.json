{
  "name": "veda-py313-uv",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff"
      ]
    }
  },
  "forwardPorts": [22],
  "postCreateCommand": "uv --version && python --version && uv sync --all-packages",
  "postStartCommand": "sudo service ssh start && bash .devcontainer/watch-uv-sync.sh /workspaces/veda >> /tmp/veda-uv-sync-watcher.log 2>&1 &"
}